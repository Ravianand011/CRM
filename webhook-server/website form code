<!--
  Innobuzz "Book Trial" form → CRM (Railway) with Google reCAPTCHA v3

  SETUP (one time):
  1. https://www.google.com/recaptcha/admin → register innobuzz.in → reCAPTCHA v3
  2. Copy Site Key into RECAPTCHA_SITE_KEY below
  3. Add Secret Key to Railway Variables: RECAPTCHA_SECRET_KEY=...
  4. Optional Railway: RECAPTCHA_MIN_SCORE=0.5  (default 0.5, range 0–1)
  5. Paste this entire block into your website page (WordPress HTML block, etc.)
-->
<style type="text/css">
  .hidden-field {
    display: none;
  }
  #custom_form_error {
    color: #e24b4a;
    font-size: 14px;
    margin-bottom: 8px;
  }
  #custom_form_message {
    color: #2e7d32;
    font-size: 14px;
    margin-bottom: 8px;
  }
  #input_submit:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }
</style>

<div id="form_wrapper" class="form_wrapper">
  <form autocomplete="off" role="form" id="custom_form" novalidate>
    <div class="form-error" id="custom_form_error"></div>
    <div class="form-message" id="custom_form_message"></div>
    <div class="form-inner">
      <div class="form-page-wrapper form-page-1 firwl-row">
        <div class="form-row form-tel form-field-1 required firwl-col firwl-m6">
          <input
            id="input_phone"
            name="phone"
            value=""
            placeholder="Phone Number"
            class="form-input"
            type="tel"
            inputmode="tel"
            autocomplete="tel"
            required
            style="height: 50px"
          />
        </div>

        <div
          class="form-row form-button-wrapper form-field-2 firwl-col firwl-m6"
        >
          <button
            type="submit"
            name="submit"
            id="input_submit"
            class="form-button btn btn-default firwl-btn__half"
            style="height: 50px; width: 150px"
          >
            Book Trial
          </button>
        </div>
      </div>
    </div>
  </form>
</div>

<script>
  (function () {
    // ── CONFIG: replace Site Key after reCAPTCHA setup ──
    var RECAPTCHA_SITE_KEY = "YOUR_RECAPTCHA_SITE_KEY";
    var CRM_WEBSITE_LEAD_URL =
      "https://crm-production-be3b.up.railway.app/website-lead";

    function loadRecaptcha(siteKey) {
      return new Promise(function (resolve, reject) {
        if (window.grecaptcha) {
          resolve();
          return;
        }
        var s = document.createElement("script");
        s.src =
          "https://www.google.com/recaptcha/api.js?render=" +
          encodeURIComponent(siteKey);
        s.async = true;
        s.onload = function () { resolve(); };
        s.onerror = function () {
          reject(new Error("Failed to load reCAPTCHA"));
        };
        document.head.appendChild(s);
      });
    }

    function getRecaptchaToken(siteKey) {
      return new Promise(function (resolve, reject) {
        grecaptcha.ready(function () {
          grecaptcha
            .execute(siteKey, { action: "book_trial" })
            .then(resolve)
            .catch(reject);
        });
      });
    }

    document.addEventListener("DOMContentLoaded", function () {
      var form = document.getElementById("custom_form");
      var messageDiv = document.getElementById("custom_form_message");
      var errorDiv = document.getElementById("custom_form_error");
      var submitBtn = document.getElementById("input_submit");

      if (RECAPTCHA_SITE_KEY === "YOUR_RECAPTCHA_SITE_KEY") {
        errorDiv.textContent =
          "Form not configured: set RECAPTCHA_SITE_KEY in the embed code.";
        submitBtn.disabled = true;
        return;
      }

      loadRecaptcha(RECAPTCHA_SITE_KEY).catch(function () {
        errorDiv.textContent = "Could not load security check. Please refresh.";
      });

      form.addEventListener("submit", function (e) {
        e.preventDefault();
        messageDiv.textContent = "";
        errorDiv.textContent = "";

        var phone = (document.getElementById("input_phone").value || "").trim();
        if (!phone) {
          errorDiv.textContent = "Please enter your phone number.";
          return;
        }

        submitBtn.disabled = true;
        var prevLabel = submitBtn.textContent;
        submitBtn.textContent = "Submitting...";

        getRecaptchaToken(RECAPTCHA_SITE_KEY)
          .then(function (recaptchaToken) {
            return fetch(CRM_WEBSITE_LEAD_URL, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ phone: phone, recaptchaToken: recaptchaToken }),
            });
          })
          .then(function (response) {
            return response.json().then(function (data) {
              return { ok: response.ok, data: data };
            });
          })
          .then(function (result) {
            if (result.ok && result.data.success !== false) {
              messageDiv.textContent =
                result.data.message || "Form submitted successfully!";
              form.reset();
            } else {
              errorDiv.textContent =
                result.data.message ||
                result.data.error ||
                "Something went wrong!";
            }
          })
          .catch(function (err) {
            console.error("Error:", err);
            errorDiv.textContent = "Network error. Please try again.";
          })
          .finally(function () {
            submitBtn.disabled = false;
            submitBtn.textContent = prevLabel;
          });
      });
    });
  })();
</script>
