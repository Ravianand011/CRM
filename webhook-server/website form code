<!-- CRM website form v4 — reCAPTCHA v3. Replace ALL old form HTML on innobuzz.in with this entire file. -->
<script
  src="https://www.google.com/recaptcha/api.js?render=6Lek1xotAAAAAL2fINsFwqIl3BXQloDL4Vn-6VEQ"
  async
  defer
></script>

<style type="text/css">
  #custom_form_error {
    color: #ff6b6b;
    font-size: 14px;
    margin-bottom: 8px;
  }
  #custom_form_message {
    color: #b8f5b8;
    font-size: 14px;
    margin-bottom: 8px;
  }
  #input_submit {
    height: 50px;
    width: 150px;
    cursor: pointer;
    border: none;
    border-radius: 4px;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    background: #ffffff;
    color: #333333;
  }
  #input_submit:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }
  .grecaptcha-badge {
    visibility: hidden;
  }
</style>

<div id="form_wrapper" class="form_wrapper">
  <form autocomplete="off" role="form" id="custom_form" novalidate>
    <div class="form-error" id="custom_form_error"></div>
    <div class="form-message" id="custom_form_message"></div>
    <div class="form-inner">
      <div class="form-page-wrapper form-page-1 firwl-row">
        <div class="form-row form-tel form-field-1 required firwl-col firwl-m6">
          <input
            id="input_phone"
            name="phone"
            value=""
            placeholder="Phone Number"
            class="form-input"
            type="tel"
            inputmode="tel"
            autocomplete="tel"
            required
            style="height: 50px"
          />
        </div>

        <div
          class="form-row form-button-wrapper form-field-2 firwl-col firwl-m6"
        >
          <input
            type="submit"
            name="submit"
            id="input_submit"
            value="Book Trial"
            class="form-button btn btn-default firwl-btn__half"
          />
        </div>
      </div>
    </div>
  </form>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    var RECAPTCHA_SITE_KEY = "6Lek1xotAAAAAL2fINsFwqIl3BXQloDL4Vn-6VEQ";
    var CRM_SUBMIT_URL =
      "https://crm-production-be3b.up.railway.app/website-lead";

    var form = document.getElementById("custom_form");
    var messageDiv = document.getElementById("custom_form_message");
    var errorDiv = document.getElementById("custom_form_error");
    var submitBtn = document.getElementById("input_submit");

    function submitLead(phone, recaptchaToken) {
      return fetch(CRM_SUBMIT_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ phone: phone, recaptchaToken: recaptchaToken }),
      }).then(function (response) {
        return response.json().then(function (resData) {
          return { ok: response.ok, data: resData };
        });
      });
    }

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      messageDiv.textContent = "";
      errorDiv.textContent = "";

      var phone = (document.getElementById("input_phone").value || "").trim();
      if (!phone) {
        errorDiv.textContent = "Please enter your phone number.";
        return;
      }

      if (typeof grecaptcha === "undefined") {
        errorDiv.textContent =
          "Could not load security check. Please refresh the page.";
        return;
      }

      submitBtn.disabled = true;
      var prevLabel = submitBtn.value;
      submitBtn.value = "Submitting...";

      grecaptcha.ready(function () {
        grecaptcha
          .execute(RECAPTCHA_SITE_KEY, { action: "book_trial" })
          .then(function (token) {
            return submitLead(phone, token);
          })
          .then(function (result) {
            if (result.ok && result.data.success !== false) {
              messageDiv.textContent =
                result.data.message || "Form submitted successfully!";
              form.reset();
            } else {
              errorDiv.textContent =
                result.data.message ||
                result.data.error ||
                "Something went wrong!";
            }
          })
          .catch(function (err) {
            console.error("Error:", err);
            errorDiv.textContent =
              "Could not verify submission. Please refresh and try again.";
          })
          .finally(function () {
            submitBtn.disabled = false;
            submitBtn.value = prevLabel;
          });
      });
    });
  });
</script>
